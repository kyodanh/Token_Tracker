{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenTracker",
  "version": "1.0.0",
  "identifier": "com.tokentracker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popup",
        "title": "TokenTracker",
        "url": "/popup.html",
        "width": 340,
        "height": 590,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "shadow": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "TokenTracker Settings",
        "url": "/settings.html",
        "width": 720,
        "height": 560,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": "-",
      "dmg": {
        "background": null,
        "windowSize": { "width": 540, "height": 380 },
        "appPosition": { "x": 160, "y": 180 },
        "applicationFolderPosition": { "x": 380, "y": 180 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    },
    "resources": [],
    "externalBin": [],
    "copyright": "© 2025 TokenTracker",
    "category": "Productivity",
    "shortDescription": "Monitor AI token usage across providers",
    "longDescription": "TokenTracker is a lightweight menu bar app that monitors and tracks your AI token usage across multiple providers including Claude, ChatGPT, OpenRouter and more."
  }
}
